# Copy to .env for local overrides. All values have dev-safe defaults, so the
# backend runs with NO .env at all. NEVER commit a real .env / secret.

# Sign JWTs with this. MUST be a long random string in production.
STRUMSIGHT_SECRET_KEY=dev-insecure-change-me-in-production

# Token lifetime (minutes). Default = 14 days (mobile-friendly).
# STRUMSIGHT_ACCESS_TOKEN_EXPIRES_MINUTES=20160

# SQLite by default. For Postgres:
# STRUMSIGHT_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/strumsight
STRUMSIGHT_DATABASE_URL=sqlite:///./strumsight.db

# CORS (JSON list). Lock this down in production.
# STRUMSIGHT_CORS_ORIGINS=["https://app.strumsight.example"]
